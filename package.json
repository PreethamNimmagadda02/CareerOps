{
  "name": "career-ops",
  "version": "1.0.0",
  "description": "AI-powered job search pipeline for Claude Code and GitHub Copilot",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "career-ops-scan": "dist/cli/scan.js",
    "career-ops-evaluate": "dist/cli/evaluate.js",
    "career-ops-pdf": "dist/cli/pdf.js",
    "career-ops-tracker": "dist/cli/tracker.js",
    "career-ops-portals": "dist/cli/portals.js"
  },
  "files": [
    "dist",
    "fonts",
    "templates"
  ],
  "scripts": {
    "scan": "tsx src/cli/scan.ts --compact --concurrency 12",
    "scan:fallback": "tsx src/cli/scan.ts --compact --fallback --concurrency 12 --browser-concurrency 8",
    "evaluate": "tsx src/cli/evaluate.ts --limit 5 --concurrency 8",
    "evaluate:all": "tsx src/cli/evaluate.ts --limit 99999 --concurrency 8",
    "evaluate:dry": "tsx src/cli/evaluate.ts --limit 5 --dry-run --concurrency 8",
    "pdf": "tsx src/cli/pdf.ts",
    "tracker": "tsx src/cli/tracker.ts",
    "portals": "tsx src/cli/portals.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,js,ts}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,js,ts}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "dynamo:init": "tsx scripts/init-dynamo.ts",
    "dynamo:init:dry": "tsx scripts/init-dynamo.ts --dry",
    "dynamo:cv": "tsx scripts/get-cv.ts",
    "dynamo:profile": "tsx scripts/get-profile.ts",
    "db:restore": "tsx scripts/restore-recovered.ts",
    "db:restore:dry": "tsx scripts/restore-recovered.ts --dry-run",
    "db:check": "tsx scripts/check-portals.ts",
    "db:backfill": "tsx scripts/backfill-scores.ts",
    "db:backfill:dry": "tsx scripts/backfill-scores.ts --dry-run",
    "db:backfill-insights": "tsx scripts/backfill-evaluations.ts",
    "db:backfill-insights:dry": "tsx scripts/backfill-evaluations.ts --dry-run",
    "db:normalize-keywords": "tsx scripts/normalize-keywords.ts",
    "db:normalize-keywords:dry": "tsx scripts/normalize-keywords.ts --dry-run",
    "db:migrate-multitenant": "tsx scripts/migrate-to-multitenant.ts",
    "db:migrate-multitenant:dry": "tsx scripts/migrate-to-multitenant.ts --dry-run",
    "db:migrate-bucket": "tsx scripts/migrate-bucket.ts",
    "db:migrate-bucket:dry": "tsx scripts/migrate-bucket.ts --dry-run",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "github-copilot",
    "career",
    "automation"
  ],
  "author": "Preetham Nimmagadda (https://github.com/PreethamNimmagadda02)",
  "homepage": "https://github.com/PreethamNimmagadda02/CareerOps",
  "repository": {
    "type": "git",
    "url": "https://github.com/PreethamNimmagadda02/CareerOps"
  },
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "openai": "^6.42.0",
    "pg": "^8.22.0",
    "playwright": "^1.58.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
