# ─────────────────────────────────────────────────────────────────────────────
# CarrerOps environment variables
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# OpenCode Zen API key (provider: zen). Get one at https://opencode.ai/auth
OPENCODE_API_KEY=sk-...

# NVIDIA build.nvidia.com API key (provider: nvidia, the default).
# Get one at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...

# Optional: override the default LLM provider / model for evaluation.
# CAREER_OPS_PROVIDER=nvidia
# CAREER_OPS_MODEL=openai/gpt-oss-120b

# ── Nextcloud (reports storage) ───────────────────────────────────────────────
# Standard Nextcloud is available at http://localhost:8090 after `docker compose up`.
# Inside the Docker network the app uses http://nextcloud:80 (set automatically).
# Update the password below if you changed it in docker-compose.yml.
NEXTCLOUD_URL=http://localhost:8090
NEXTCLOUD_USER=admin
NEXTCLOUD_PASSWORD=careerops123

# ── MinIO (report object storage) ─────────────────────────────────────────────
# S3-compatible storage for evaluation report markdown. The evaluator stores the
# object name in Postgres `Application.reportName` and a resolvable URL in
# `Application.reportUrl`.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=careerops123
MINIO_BUCKET=careerops-reports
# Optional: browser-reachable endpoint used to build `reportUrl`. Falls back to
# MINIO_ENDPOINT. Set this when the app talks to MinIO over an internal host
# (e.g. http://minio:9000) but report URLs must be opened from a browser.
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ── DynamoDB (profile & CV store) ─────────────────────────────────────────────
# For local dev / Docker: point at DynamoDB Local (port 8000).
# For real AWS: remove DYNAMODB_ENDPOINT and set real AWS credentials.
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=us-east-1
DYNAMODB_TABLE_CV=CVs
DYNAMODB_TABLE_PROFILE=Profiles
# Dummy credentials for DynamoDB Local (ignored by real AWS — use IAM / ~/.aws there).
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
