# ─────────────────────────────────────────────────────────────────────────────
# CarrerOps environment variables
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# OpenCode Zen API key (provider: zen). Get one at https://opencode.ai/auth
OPENCODE_API_KEY=sk-...

# NVIDIA build.nvidia.com API key (provider: nvidia, the default).
# Get one at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...

# Optional: override the default LLM provider / model for evaluation.
# CAREER_OPS_PROVIDER=nvidia
# CAREER_OPS_MODEL=openai/gpt-oss-120b
