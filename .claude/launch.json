{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "worker",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "worker"],
      "port": 0
    },
    {
      "name": "docker-infra",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up", "db", "minio", "dynamodb", "redis"],
      "port": 5432
    }
  ]
}
