# ─────────────────────────────────────────────────────────────────────────────
# Production environment reference (AWS).
#
# These values are NOT loaded from a file in production — they are injected into
# ECS tasks by Terraform (non-secrets as task env, secrets from Secrets Manager).
# This file documents the full runtime contract for reference / debugging.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Auth.js (web) ────────────────────────────────────────────────────────────
AUTH_SECRET=                      # secret — openssl rand -base64 33
AUTH_URL=https://careerops.example.com
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Postgres (RDS) ───────────────────────────────────────────────────────────
# Built by Terraform; includes sslmode=require. Stored in Secrets Manager.
DATABASE_URL=postgresql://careerops:***@<rds-endpoint>:5432/careerops?schema=public&sslmode=require

# ── S3 (reports + resumes) ───────────────────────────────────────────────────
# IMPORTANT: leave MINIO_ENDPOINT UNSET in production so the SDK uses the native
# S3 endpoint and the ECS task IAM role for credentials (no static keys).
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
MINIO_BUCKET=careerops-prod-reports-<account-id>
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=false
# CloudFront distribution that fronts the reports bucket (bucket root).
REPORTS_PUBLIC_BASE_URL=https://dxxxxxxxxxxxxx.cloudfront.net

# ── DynamoDB (CV + Profile) ──────────────────────────────────────────────────
# Leave DYNAMODB_ENDPOINT UNSET for real AWS (uses the IAM task role).
# DYNAMODB_ENDPOINT=
DYNAMODB_REGION=us-east-1
DYNAMODB_TABLE_CV=CVs
DYNAMODB_TABLE_PROFILE=Profiles

# ── LLM providers ────────────────────────────────────────────────────────────
NVIDIA_API_KEY=                   # secret
OPENCODE_API_KEY=                 # secret (optional)

# ── Pipeline (scale-out) ─────────────────────────────────────────────────────
PIPELINE_MODE=sqs                 # "sqs" = decoupled worker; "inline" = legacy
PIPELINE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account>/careerops-prod-pipeline
PIPELINE_VISIBILITY_SECONDS=900

AWS_REGION=us-east-1
