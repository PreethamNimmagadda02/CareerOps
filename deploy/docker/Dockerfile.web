# syntax=docker/dockerfile:1.7
# ─────────────────────────────────────────────────────────────────────────────
# Web image (Next.js dashboard + API).
#
# In production the web tier does NOT spawn the pipeline (PIPELINE_MODE=sqs), so
# it needs no Chromium — a slim Node base keeps it small and fast to scale.
# It still talks to Postgres (Prisma), DynamoDB, S3 and SQS via the bundled
# src/lib modules.
#
# Build context = repo root:
#   docker build -f deploy/docker/Dockerfile.web -t careerops-web .
#
# `npm ci` uses a BuildKit cache mount + higher fetch-retry count so a
# transient registry blip doesn't fail the whole (CI) build.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-bookworm-slim AS build

WORKDIR /app
RUN npm config set fetch-retries 5 fetch-retry-mintimeout 20000 fetch-retry-maxtimeout 120000

# Root deps (src/lib is imported by the web app: prisma, pg, aws-sdk…).
COPY package.json package-lock.json prisma.config.ts ./
COPY prisma ./prisma
RUN --mount=type=cache,target=/root/.npm npm ci --ignore-scripts
RUN npx prisma generate

# Web deps.
COPY web/package.json web/package-lock.json ./web/
RUN --mount=type=cache,target=/root/.npm cd web && npm ci --ignore-scripts

# Sources and build.
COPY tsconfig.json ./
COPY src ./src
COPY web ./web
RUN cd web && npm run build

# ── Runtime ──────────────────────────────────────────────────────────────────
FROM node:22-bookworm-slim AS runtime

ENV NODE_ENV=production
WORKDIR /app
RUN npm config set fetch-retries 5 fetch-retry-mintimeout 20000 fetch-retry-maxtimeout 120000

# Root production deps + generated Prisma client (engine needed at runtime).
COPY package.json package-lock.json prisma.config.ts ./
COPY prisma ./prisma
RUN --mount=type=cache,target=/root/.npm npm ci --omit=dev --ignore-scripts
RUN npx prisma generate

# Built Next.js app + its runtime deps.
COPY --from=build /app/web/.next ./web/.next
COPY --from=build /app/web/package.json ./web/package.json
COPY --from=build /app/web/node_modules ./web/node_modules

EXPOSE 3000
# `next start` binds 0.0.0.0:$PORT (PORT/HOSTNAME provided by the task def).
CMD ["npm", "start", "--prefix", "web"]
