generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth.js (NextAuth v5) models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// MinIO object key for the uploaded resume (e.g. "resumes/<id>.pdf").
  resumeKey       String?
  resumeUpdatedAt DateTime?

  /// Per-user monotonic report counter. Allocated atomically via
  /// `UPDATE … SET reportSeq = reportSeq + 1 RETURNING reportSeq` so report
  /// numbers are unique + gap-tolerant per tenant without a global table scan.
  /// See `nextReportNumber()` in src/lib/tracker.ts.
  reportSeq       Int       @default(0)

  accounts       Account[]
  sessions       Session[]
  applications   Application[]
  filterKeywords FilterKeyword[]
  jobs           Job[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// VerificationToken omitted — only OAuth providers are used.

// ─────────────────────────────────────────────────────────────────────────────
// Domain models
// ─────────────────────────────────────────────────────────────────────────────

enum AppStatus {
  Evaluated
  Applied
  Responded
  Interview
  Offer
  Rejected
  Discarded
  SKIP
}

model Application {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String
  date      String
  company   String
  role      String
  score     String
  status    AppStatus
  pdf       String
  reportName    String
  reportUrl String?
  url       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // ── Evaluation insights ─────────────────────────────────────────────────
  // Parsed from the LLM report once at evaluate time so the dashboard can
  // sort/filter without re-reading report markdown from MinIO on every list.
  /// Overall score as a number (mirrors `score`, e.g. 4.2).
  scoreNumeric   Float?
  /// APPLY_NOW | APPLY_WITH_TWEAKS | MONITOR | SKIP
  recommendation String?
  archetype      String?
  tldr           String?
  remote         String?
  /// One-line compensation estimate from report section D.
  comp           String?
  /// { dimensions: [{key,label,weight,score,reason}], gaps: [], recommendationNote }
  insights       Json?
  evaluatedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId])
}

/// A scan target — global, shared across all users.
model Portal {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique
  careersUrl String?
  api        String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Title-filter keywords (formerly `title_filter.positive` / `.negative`).
model FilterKeyword {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String
  kind   String // "positive" | "negative"
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, value])
  @@index([userId])
}

/// A discovered job posting — GLOBAL, shared across all users. The scheduled
/// shared scan fetches every portal ONCE and upserts postings here; each user's
/// "scan" then just matches this corpus against their own preferences (cheap,
/// no scraping) instead of re-fetching all ~685 boards per user. `active` is
/// flipped false for postings not seen in the latest scan (i.e. filled/removed).
model Posting {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url         String    @unique
  company     String
  title       String
  location    String    @default("")
  source      String    @default("")
  active      Boolean   @default(true)
  /// Cached job-description text, fetched once globally so per-user evaluation
  /// doesn't re-scrape the same posting N times.
  jd          String?   @db.Text
  jdFetchedAt DateTime?

  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Per-user matching queries the active corpus.
  @@index([active])
  @@index([company])
}

// ─────────────────────────────────────────────────────────────────────────────
// Pipeline job queue
// ─────────────────────────────────────────────────────────────────────────────

enum JobStatus {
  Queued
  Running
  Succeeded
  Failed
  Canceled
}

/// A queued pipeline run (scan / evaluate). The web tier enqueues one of these
/// and returns immediately; a separate worker process claims it (via
/// `FOR UPDATE SKIP LOCKED`), runs the heavy Playwright/LLM work off the web
/// nodes, and streams progress back into `log`. The dashboard polls the row for
/// status + output instead of holding an 800s HTTP stream.
model Job {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String
  /// PipelineCommand: scan | scan:fallback | evaluate | evaluate:all | evaluate:dry
  command   String
  status    JobStatus @default(Queued)
  /// Rolling captured stdout/stderr (bounded by the worker before each flush).
  log       String    @default("") @db.Text
  exitCode  Int?
  error     String?
  attempts  Int       @default(0)
  /// Set by a cancel request; the worker kills the child at the next heartbeat.
  cancelRequested Boolean @default(false)

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  /// Liveness timestamp bumped by the running worker; stale rows are reclaimed.
  heartbeatAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Worker claim scans Queued jobs oldest-first; dashboard lists a user's jobs.
  @@index([status, createdAt])
  @@index([userId, createdAt])
}
