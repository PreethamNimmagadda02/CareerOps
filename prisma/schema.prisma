generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth.js (NextAuth v5) models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// MinIO object key for the uploaded resume (e.g. "resumes/<id>.pdf").
  resumeKey       String?
  resumeUpdatedAt DateTime?

  accounts       Account[]
  sessions       Session[]
  applications   Application[]
  filterKeywords FilterKeyword[]
  pipelineRuns   PipelineRun[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// VerificationToken omitted — only OAuth providers are used.

// ─────────────────────────────────────────────────────────────────────────────
// Domain models
// ─────────────────────────────────────────────────────────────────────────────

enum AppStatus {
  Evaluated
  Applied
  Responded
  Interview
  Offer
  Rejected
  Discarded
  SKIP
}

model Application {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String
  date      String
  company   String
  role      String
  score     String
  status    AppStatus
  pdf       String
  reportName    String
  reportUrl String?
  url       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId])
}

/// A scan target — global, shared across all users.
model Portal {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique
  careersUrl String?
  api        String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// A single pipeline execution (scan / evaluate). Used only when the app runs
/// in decoupled mode (PIPELINE_MODE=sqs): the web tier creates a row + enqueues
/// an SQS message, the worker tier updates status/logs as it runs, and the web
/// tier tails `logs` back to the browser. Unused in inline mode.
model PipelineRun {
  id         String    @id @default(cuid())
  userId     String
  command    String
  /// queued | running | succeeded | failed | canceled
  status     String    @default("queued")
  /// Accumulated stdout/stderr, appended by the worker as the job runs.
  logs       String    @default("") @db.Text
  exitCode   Int?
  error      String?
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

/// Title-filter keywords (formerly `title_filter.positive` / `.negative`).
model FilterKeyword {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String
  kind   String // "positive" | "negative"
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, value])
  @@index([userId])
}
